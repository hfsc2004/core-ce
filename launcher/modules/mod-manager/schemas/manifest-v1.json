{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "psf://schemas/mod-manifest-v1.json",
  "title": "PSF Mod Manifest v1",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "apiVersion",
    "apiRange",
    "entrypoint",
    "capabilities"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9._-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+([.-][A-Za-z0-9]+)?$"
    },
    "apiVersion": {
      "type": "integer",
      "minimum": 1
    },
    "apiRange": {
      "type": "object",
      "required": [
        "min",
        "max"
      ],
      "properties": {
        "min": {
          "type": "integer",
          "minimum": 1
        },
        "max": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "entrypoint": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "editionSupport": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}

