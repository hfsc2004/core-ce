  "groups": [],
  "_moeDocumentation": {
    "purpose": "This file serves as the configuration layer for model ordering and the future MoE system.",
    "bmocHandoff": {
      "ipcChannel": "moe:deploy-configuration",
      "handler": "session-manager.js",
      "description": "When MoE deployment is triggered, BMOC (session-manager.js) reads this file to spin up Ollama instances with proper role assignments and port allocations from the Agent pool (53000-62999)."
    },
    "groupSchema": {
      "id": "Unique group identifier (group-timestamp-random)",
      "name": "User-defined display name",
      "modelIds": "Array of model IDs belonging to this group",
      "color": "Hex color for UI display",
      "moeConfig": {
        "role": "MoE role assignment (null until Enterprise MoE implementation)",
        "priority": "Execution priority (1=highest, null=unset)",
        "routingWeight": "Load balancing weight (0.0-1.0, null=unset)",
        "connectionType": "External connection type: null, 'usb', 'api', 'tcp'"
      }
    },
    "futureFields": [
      "roleDefinitions - Map of role names to configurations",
      "functionDefinitions - Map of function names to action chains",
      "externalEndpoints - USB/API/TCP endpoint configurations",
      "coordinatorConfig - MoE orchestration settings"
    ]
  }
